<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Mapa — @<%= client.username %></title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;500;700;900&family=Instrument+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #08080a;
  --bg2:     #0f0f12;
  --bg3:     #161619;
  --bg4:     #1c1c21;
  --bg5:     #222228;
  --line:    rgba(255,255,255,0.06);
  --line2:   rgba(255,255,255,0.1);
  --text:    #ece9e3;
  --muted:   #7a7872;
  --muted2:  #4a4845;
  --gold:    #c9a96e;
  --gold2:   #e8cb94;
  --gold-bg: rgba(201,169,110,0.08);
  --gold-bd: rgba(201,169,110,0.18);
  --green:   #52b788;
  --green-bg:rgba(82,183,136,0.09);
  --green-bd:rgba(82,183,136,0.22);
  --red:     #e05252;
  --red-bg:  rgba(224,82,82,0.09);
  --red-bd:  rgba(224,82,82,0.22);
  --blue:    #6b9fe4;
  --blue-bg: rgba(107,159,228,0.09);
  --blue-bd: rgba(107,159,228,0.22);
  --amber:   #e09a45;
  --amber-bg:rgba(224,154,69,0.09);
  --amber-bd:rgba(224,154,69,0.22);
  --purple:  #a385e0;
  --purple-bg:rgba(163,133,224,0.09);
  --purple-bd:rgba(163,133,224,0.22);
  --r:  8px;
  --r2: 12px;
  --r3: 16px;
  --r4: 20px;
}

*{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Instrument Sans',sans-serif;
  font-size:14px;
  line-height:1.6;
  max-width:430px;
  margin:0 auto;
  padding-bottom:60px;
  overflow-x:hidden;
}

.nav{
  position:sticky;top:0;z-index:200;
  background:rgba(8,8,10,0.88);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:0.5px solid var(--line2);
  padding:0 16px;
  display:flex;align-items:center;justify-content:space-between;
  height:52px;
}
.nav-logo{
  font-family:'Unbounded',sans-serif;
  font-size:10px;font-weight:700;
  letter-spacing:0.16em;text-transform:uppercase;
  color:var(--gold);
}
.nav-right{display:flex;align-items:center;gap:8px;}
.nav-date{font-size:11px;color:var(--muted);}
.nav-chip{
  background:var(--green-bg);border:0.5px solid var(--green-bd);
  color:var(--green);font-size:10px;font-weight:500;
  padding:3px 8px;border-radius:20px;letter-spacing:0.04em;
}

.tabs-wrap{
  position:sticky;top:52px;z-index:190;
  background:rgba(8,8,10,0.95);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:0.5px solid var(--line);
  overflow-x:auto;scrollbar-width:none;
  -ms-overflow-style:none;
}
.tabs-wrap::-webkit-scrollbar{display:none;}
.tabs{
  display:flex;align-items:center;
  padding:0 16px;gap:0;
  min-width:max-content;
}
.tab{
  padding:13px 14px;
  font-size:11px;font-weight:500;letter-spacing:0.04em;
  color:var(--muted);
  border-bottom:1.5px solid transparent;
  cursor:pointer;transition:all .2s;
  white-space:nowrap;
  display:flex;align-items:center;gap:5px;
}
.tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab-dot{
  width:5px;height:5px;border-radius:50%;
  background:var(--muted2);flex-shrink:0;
}
.tab.active .tab-dot{background:var(--gold);}

.section{display:none;padding:0 0 8px;}
.section.active{display:block;}

.profile-hero{
  margin:16px;
  background:var(--bg3);
  border:0.5px solid var(--line2);
  border-radius:var(--r3);
  overflow:hidden;
}
.profile-banner{
  height:80px;
  background:linear-gradient(135deg,#1a1508 0%,#2a1f0a 40%,#1a1508 100%);
  position:relative;
  display:flex;align-items:flex-end;
  padding:0 16px 0;
}
.profile-banner::after{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(
    -45deg,transparent,transparent 8px,
    rgba(201,169,110,0.03) 8px,rgba(201,169,110,0.03) 9px
  );
}
.profile-avatar-wrap{
  position:relative;z-index:1;
  margin-bottom:-22px;
}
.profile-avatar{
  width:56px;height:56px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--amber));
  border:2.5px solid var(--bg3);
  display:flex;align-items:center;justify-content:center;
  font-family:'Unbounded',sans-serif;
  font-size:16px;font-weight:700;color:var(--bg);
}
.profile-avatar img{
  width:100%;height:100%;border-radius:50%;object-fit:cover;
}
.profile-body{padding:28px 16px 16px;}
.profile-name{
  font-family:'Unbounded',sans-serif;
  font-size:15px;font-weight:700;
  margin-bottom:2px;letter-spacing:-0.01em;
}
.profile-handle{font-size:12px;color:var(--muted);margin-bottom:12px;}
.profile-bio{
  font-size:12px;color:var(--muted);line-height:1.6;
  padding:10px 12px;
  background:var(--bg4);border-radius:var(--r);
  border:0.5px solid var(--line);
  margin-bottom:14px;
  font-style:italic;
}
.profile-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.pstat{
  background:var(--bg4);border:0.5px solid var(--line);
  border-radius:var(--r);padding:10px 8px;text-align:center;
}
.pstat-val{
  font-family:'Unbounded',sans-serif;
  font-size:14px;font-weight:700;color:var(--gold);
  margin-bottom:2px;display:block;
}
.pstat-lbl{font-size:9px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}
.profile-tags{margin:12px 16px 0;display:flex;flex-wrap:wrap;gap:6px;}
.ptag{
  font-size:10px;font-weight:500;
  padding:4px 10px;border-radius:20px;
  letter-spacing:0.04em;
}
.ptag-gold{background:var(--gold-bg);border:0.5px solid var(--gold-bd);color:var(--gold);}
.ptag-blue{background:var(--blue-bg);border:0.5px solid var(--blue-bd);color:var(--blue);}
.ptag-green{background:var(--green-bg);border:0.5px solid var(--green-bd);color:var(--green);}
.ptag-amber{background:var(--amber-bg);border:0.5px solid var(--amber-bd);color:var(--amber);}

.profile-metrics{margin:12px 16px 0;}
.pm-title{
  font-size:10px;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--muted);margin-bottom:8px;font-weight:500;
}
.pm-rows{display:flex;flex-direction:column;gap:6px;}
.pm-row{display:flex;align-items:center;gap:8px;}
.pm-label{font-size:11px;color:var(--muted);width:100px;flex-shrink:0;}
.pm-track{flex:1;height:3px;background:var(--bg5);border-radius:2px;overflow:hidden;}
.pm-fill{height:100%;border-radius:2px;}
.pm-pct{font-size:10px;color:var(--muted);width:24px;text-align:right;flex-shrink:0;}
.apify-badge{
  margin:16px 16px 0;
  display:flex;align-items:center;gap:6px;
  font-size:10px;color:var(--muted2);
}
.apify-badge span{
  background:var(--bg4);border:0.5px solid var(--line);
  border-radius:6px;padding:3px 8px;
  font-size:9px;letter-spacing:0.06em;text-transform:uppercase;
  color:var(--muted);
}

.block{
  margin:16px;
  background:var(--bg3);
  border:0.5px solid var(--line2);
  border-radius:var(--r3);
  overflow:hidden;
}
.block-head{
  padding:14px 16px 12px;
  border-bottom:0.5px solid var(--line);
  display:flex;align-items:center;justify-content:space-between;
}
.block-head-left{display:flex;align-items:center;gap:8px;}
.block-icon{
  width:28px;height:28px;border-radius:7px;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;flex-shrink:0;
}
.block-title{
  font-family:'Unbounded',sans-serif;
  font-size:11px;font-weight:700;letter-spacing:0.04em;
}
.block-source{
  font-size:9px;letter-spacing:0.1em;text-transform:uppercase;
  font-weight:500;padding:3px 8px;border-radius:20px;
}
.src-ia{background:var(--purple-bg);color:var(--purple);border:0.5px solid var(--purple-bd);}
.src-manual{background:var(--blue-bg);color:var(--blue);border:0.5px solid var(--blue-bd);}
.src-apify{background:var(--amber-bg);color:var(--amber);border:0.5px solid var(--amber-bd);}
.block-body{padding:16px;}

.narr-hook{
  font-size:13px;color:var(--text);line-height:1.7;
  padding:12px 14px;
  background:var(--bg4);border-radius:var(--r);
  border-left:2px solid var(--gold);
  margin-bottom:12px;
  font-style:italic;
}
.narr-grid{display:flex;flex-direction:column;gap:8px;}
.narr-item{
  display:flex;gap:10px;align-items:flex-start;
  padding:10px 12px;
  background:var(--bg4);border-radius:var(--r);
  border:0.5px solid var(--line);
}
.narr-label{
  font-size:9px;font-weight:600;letter-spacing:0.1em;
  text-transform:uppercase;margin-bottom:3px;
}
.narr-text{font-size:12px;color:var(--muted);line-height:1.55;}
.narr-num{
  font-family:'Unbounded',sans-serif;
  font-size:10px;font-weight:700;color:var(--gold);opacity:0.4;
  flex-shrink:0;margin-top:1px;
}

.formato-intro{
  font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:14px;
}
.headline-block{
  background:var(--bg4);border-radius:var(--r2);
  border:0.5px solid var(--gold-bd);
  padding:14px;margin-bottom:10px;
}
.hl-tag{
  font-size:9px;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--gold);font-weight:600;margin-bottom:8px;
  display:flex;align-items:center;gap:5px;
}
.hl-tag::before{content:'◆';font-size:7px;}
.hl-text{
  font-family:'Unbounded',sans-serif;
  font-size:13px;font-weight:700;
  line-height:1.4;color:var(--text);
  margin-bottom:8px;
}
.hl-why{font-size:11px;color:var(--muted);line-height:1.5;}

.roteiro-block{
  background:var(--bg4);border-radius:var(--r2);
  border:0.5px solid var(--line2);
  overflow:hidden;margin-bottom:10px;
}
.roteiro-head{
  padding:10px 14px;
  border-bottom:0.5px solid var(--line);
  display:flex;align-items:center;justify-content:space-between;
}
.roteiro-title{font-size:11px;font-weight:500;color:var(--muted);letter-spacing:0.04em;}
.roteiro-badge{
  font-size:9px;padding:2px 7px;border-radius:10px;
  background:var(--green-bg);color:var(--green);border:0.5px solid var(--green-bd);
  letter-spacing:0.04em;
}
.roteiro-steps{padding:12px 14px;display:flex;flex-direction:column;gap:0;}
.rstep{display:flex;gap:10px;align-items:stretch;}
.rstep-left{
  display:flex;flex-direction:column;align-items:center;
  width:24px;flex-shrink:0;
}
.rstep-dot{
  width:20px;height:20px;border-radius:50%;
  background:var(--bg5);border:1px solid var(--line2);
  display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:700;color:var(--muted);
  flex-shrink:0;
}
.rstep-dot.act{background:var(--gold-bg);border-color:var(--gold-bd);color:var(--gold);}
.rstep-line{flex:1;width:1px;background:var(--line);margin:2px 0;}
.rstep:last-child .rstep-line{display:none;}
.rstep-body{flex:1;padding:0 0 14px 10px;}
.rstep-name{font-size:11px;font-weight:500;color:var(--text);margin-bottom:3px;}
.rstep-desc{font-size:11px;color:var(--muted);line-height:1.5;}
.rstep-ex{
  margin-top:6px;padding:8px 10px;
  background:var(--bg5);border-radius:var(--r);
  border:0.5px solid var(--line);
  font-size:11px;color:var(--muted);line-height:1.5;font-style:italic;
}

.ref-intro{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
.ref-list{display:flex;flex-direction:column;gap:10px;}
.ref-card{
  background:var(--bg4);border-radius:var(--r2);
  border:0.5px solid var(--line2);
  padding:12px 14px;
  display:flex;gap:12px;align-items:flex-start;
}
.ref-avatar{
  width:38px;height:38px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:'Unbounded',sans-serif;
  font-size:11px;font-weight:700;
  flex-shrink:0;
  border:1px solid var(--line2);
  overflow:hidden;
}
.ref-avatar img{width:100%;height:100%;object-fit:cover;}
.ref-body{flex:1;min-width:0;}
.ref-name{font-size:12px;font-weight:500;color:var(--text);margin-bottom:1px;}
.ref-handle{font-size:11px;color:var(--muted);margin-bottom:6px;}
.ref-stats{font-size:10px;color:var(--muted);margin-bottom:6px;}

.termos-intro{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
.termo-list{display:flex;flex-direction:column;gap:8px;}
.termo-card{
  background:var(--bg4);border-radius:var(--r2);
  border:0.5px solid var(--line2);
  padding:12px 14px;
}
.termo-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.termo-word{
  font-family:'Unbounded',sans-serif;
  font-size:12px;font-weight:700;color:var(--text);
}
.termo-desc{font-size:11px;color:var(--muted);line-height:1.5;}

.plano-intro{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:14px;}
.plano-kpis{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:14px;}
.pkpi{
  background:var(--bg4);border:0.5px solid var(--line);
  border-radius:var(--r);padding:10px 12px;
}
.pkpi-val{
  font-family:'Unbounded',sans-serif;
  font-size:16px;font-weight:700;margin-bottom:2px;
}
.pkpi-lbl{font-size:10px;color:var(--muted);letter-spacing:0.04em;}
.acao-list{display:flex;flex-direction:column;gap:0;}
.acao-item{display:flex;gap:0;align-items:stretch;}
.acao-left{
  display:flex;flex-direction:column;align-items:center;
  width:36px;flex-shrink:0;padding-top:2px;
}
.acao-dot{
  width:24px;height:24px;border-radius:50%;
  background:var(--bg4);border:1px solid var(--line2);
  display:flex;align-items:center;justify-content:center;
  font-family:'Unbounded',sans-serif;
  font-size:9px;font-weight:700;color:var(--muted);
  flex-shrink:0;z-index:1;
}
.acao-dot.p1{background:var(--red-bg);border-color:var(--red-bd);color:var(--red);}
.acao-dot.p2{background:var(--amber-bg);border-color:var(--amber-bd);color:var(--amber);}
.acao-dot.p3{background:var(--blue-bg);border-color:var(--blue-bd);color:var(--blue);}
.acao-vline{flex:1;width:1px;background:var(--line);margin:3px 0;}
.acao-item:last-child .acao-vline{display:none;}
.acao-body{flex:1;padding:0 0 20px 12px;}
.acao-top{
  display:flex;align-items:flex-start;
  justify-content:space-between;gap:6px;margin-bottom:5px;
}
.acao-title{
  font-size:13px;font-weight:500;color:var(--text);
  line-height:1.35;
}
.acao-prazo{
  font-size:9px;font-weight:600;letter-spacing:0.06em;
  text-transform:uppercase;padding:3px 7px;
  border-radius:6px;flex-shrink:0;margin-top:1px;
}
.pz-urgente{background:var(--red-bg);color:var(--red);border:0.5px solid var(--red-bd);}
.pz-semana{background:var(--amber-bg);color:var(--amber);border:0.5px solid var(--amber-bd);}
.pz-mes{background:var(--blue-bg);color:var(--blue);border:0.5px solid var(--blue-bd);}
.pz-continuo{background:var(--purple-bg);color:var(--purple);border:0.5px solid var(--purple-bd);}
.acao-desc{font-size:11px;color:var(--muted);line-height:1.55;}
.acao-subs{margin-top:7px;display:flex;flex-direction:column;gap:4px;}
.acao-sub{
  display:flex;gap:6px;align-items:flex-start;
  font-size:11px;color:var(--muted);line-height:1.45;
}
.acao-sub::before{
  content:'→';color:var(--gold);opacity:0.45;
  flex-shrink:0;font-size:10px;margin-top:1px;
}

.narr-content{
  font-size:12px;color:var(--muted);line-height:1.7;
  white-space:pre-wrap;
}

.footer{
  margin:24px 16px 0;
  background:var(--bg3);
  border:0.5px solid var(--gold-bd);
  border-radius:var(--r3);
  padding:18px;
  text-align:center;
}
.footer-label{
  font-size:9px;letter-spacing:0.14em;text-transform:uppercase;
  color:var(--gold);font-weight:600;margin-bottom:6px;
}
.footer-text{
  font-family:'Unbounded',sans-serif;
  font-size:13px;font-weight:700;
  line-height:1.35;margin-bottom:8px;letter-spacing:-0.01em;
}
.footer-sub{font-size:11px;color:var(--muted);line-height:1.5;margin-bottom:14px;}
.footer-date{
  font-size:10px;color:var(--muted2);
  letter-spacing:0.06em;
}

@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.fade-up{opacity:0;animation:fadeUp .4s ease forwards;}
</style>
</head>
<body>

<%
  // Helper: initials from name
  function initials(name) {
    if (!name) return '??';
    return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
  }
  // Helper: format number
  function fmtNum(n) {
    if (!n) return '—';
    if (n >= 1000000) return (n / 1000000).toFixed(1).replace('.0', '') + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'K';
    return String(n);
  }
  const profileName = (client.data && client.data.fullName) || (extractedProfile && extractedProfile.nome) || client.username;
  const profileInitials = initials(profileName);
  const tagColors = ['ptag-gold', 'ptag-blue', 'ptag-green', 'ptag-amber'];
  const narrColors = ['var(--red)', 'var(--amber)', 'var(--green)', 'var(--blue)', 'var(--purple)'];
  const priorityClasses = ['p1', 'p1', 'p2', 'p2', 'p3', 'p3', 'p3', 'p3', 'p3', 'p3'];
  const prazoClasses = ['pz-urgente', 'pz-urgente', 'pz-semana', 'pz-semana', 'pz-mes', 'pz-mes', 'pz-mes', 'pz-continuo', 'pz-continuo', 'pz-continuo'];
  const prazoLabels = ['Urgente', 'Urgente', 'Esta semana', 'Esta semana', 'Este mês', 'Este mês', 'Este mês', 'Contínuo', 'Contínuo', 'Contínuo'];
%>

<!-- NAV -->
<div class="nav">
  <span class="nav-logo">Mapa do Mentorado</span>
  <div class="nav-right">
    <span class="nav-date"><%= generatedAt %></span>
    <span class="nav-chip">@<%= client.username %></span>
  </div>
</div>

<!-- TABS -->
<div class="tabs-wrap">
  <div class="tabs" id="tabs">
    <div class="tab active" data-tab="perfil">
      <span class="tab-dot"></span>Perfil
    </div>
    <div class="tab" data-tab="narrativa">
      <span class="tab-dot"></span>Narrativa
    </div>
    <div class="tab" data-tab="formato">
      <span class="tab-dot"></span>Formato Viral
    </div>
    <div class="tab" data-tab="referencias">
      <span class="tab-dot"></span>Referências
    </div>
    <div class="tab" data-tab="termos">
      <span class="tab-dot"></span>Termos Virais
    </div>
    <div class="tab" data-tab="plano">
      <span class="tab-dot"></span>Plano de Ação
    </div>
  </div>
</div>

<!-- ── 1. PERFIL ── -->
<div class="section active fade-up" id="sec-perfil">
  <div class="profile-hero">
    <div class="profile-banner">
      <div class="profile-avatar-wrap">
        <div class="profile-avatar">
          <% if (client.data && client.data.profilePicUrl) { %>
            <img src="<%= client.data.profilePicUrl %>" alt="@<%= client.username %>">
          <% } else { %>
            <%= profileInitials %>
          <% } %>
        </div>
      </div>
    </div>
    <div class="profile-body">
      <p class="profile-name"><%= profileName %></p>
      <p class="profile-handle">@<%= client.username %><% if (extractedProfile && extractedProfile.especialidade) { %> · <%= extractedProfile.especialidade %><% } %></p>
      <% if (client.data && client.data.biography) { %>
        <div class="profile-bio">"<%= client.data.biography %>"</div>
      <% } %>
      <div class="profile-stats">
        <div class="pstat">
          <span class="pstat-val"><%= fmtNum(client.data && client.data.followersCount) %></span>
          <span class="pstat-lbl">Seguidores</span>
        </div>
        <div class="pstat">
          <span class="pstat-val"><%= fmtNum(client.data && client.data.followsCount) %></span>
          <span class="pstat-lbl">Seguindo</span>
        </div>
        <div class="pstat">
          <span class="pstat-val"><%= fmtNum(client.data && client.data.postsCount) %></span>
          <span class="pstat-lbl">Posts</span>
        </div>
      </div>
    </div>
  </div>

  <% if (extractedProfile) { %>
  <div class="profile-tags">
    <% if (extractedProfile.especialidade) { %><span class="ptag ptag-gold"><%= extractedProfile.especialidade %></span><% } %>
    <% if (extractedProfile.publico_alvo) { %><span class="ptag ptag-blue"><%= extractedProfile.publico_alvo %></span><% } %>
    <% if (extractedProfile.desejo) { %><span class="ptag ptag-green"><%= extractedProfile.desejo %></span><% } %>
    <% if (extractedProfile.nova_crenca) { %><span class="ptag ptag-amber"><%= extractedProfile.nova_crenca %></span><% } %>
  </div>

  <!-- Núcleo de influência -->
  <div class="block" style="margin-top:12px;">
    <div class="block-head">
      <div class="block-head-left">
        <div class="block-icon" style="background:var(--gold-bg);">◈</div>
        <span class="block-title">Núcleo de Influência</span>
      </div>
      <span class="block-source src-ia">IA + Call</span>
    </div>
    <div class="block-body">
      <div class="narr-grid">
        <div class="narr-item">
          <span class="narr-num">01</span>
          <div>
            <p class="narr-label" style="color:var(--red);">Dor principal</p>
            <p class="narr-text"><%= extractedProfile.dor %></p>
          </div>
        </div>
        <div class="narr-item">
          <span class="narr-num">02</span>
          <div>
            <p class="narr-label" style="color:var(--amber);">Inimigo</p>
            <p class="narr-text"><%= extractedProfile.inimigo %></p>
          </div>
        </div>
        <div class="narr-item">
          <span class="narr-num">03</span>
          <div>
            <p class="narr-label" style="color:var(--green);">Desejo / Transformação</p>
            <p class="narr-text"><%= extractedProfile.desejo %></p>
          </div>
        </div>
        <div class="narr-item">
          <span class="narr-num">04</span>
          <div>
            <p class="narr-label" style="color:var(--blue);">Nova Crença</p>
            <p class="narr-text"><%= extractedProfile.nova_crenca %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <div class="apify-badge" style="padding:0 16px 16px;">
    <span>Dados coletados em <%= generatedAt %></span>
  </div>
</div>

<!-- ── 2. NARRATIVA ── -->
<div class="section" id="sec-narrativa">
  <div class="block fade-up">
    <div class="block-head">
      <div class="block-head-left">
        <div class="block-icon" style="background:var(--purple-bg);">✦</div>
        <span class="block-title">Narrativa Magnética</span>
      </div>
      <span class="block-source src-ia">IA + Call</span>
    </div>
    <div class="block-body">
      <% if (narrative) { %>
        <div class="narr-content"><%= narrative %></div>
      <% } else { %>
        <p style="color:var(--muted);font-size:12px;">Narrativa não gerada.</p>
      <% } %>
    </div>
  </div>
</div>

<!-- ── 3. FORMATO VIRAL ── -->
<div class="section" id="sec-formato">
  <div class="block fade-up">
    <div class="block-head">
      <div class="block-head-left">
        <div class="block-icon" style="background:var(--gold-bg);">◈</div>
        <span class="block-title">Formato Viral</span>
      </div>
      <span class="block-source src-ia">IA + Base</span>
    </div>
    <div class="block-body">
      <% if (viralFormat) { %>
        <div class="narr-content"><%= viralFormat %></div>
      <% } else { %>
        <p style="color:var(--muted);font-size:12px;">Formato viral não informado.</p>
      <% } %>
    </div>
  </div>
</div>

<!-- ── 4. REFERÊNCIAS ── -->
<div class="section" id="sec-referencias">
  <div class="block fade-up">
    <div class="block-head">
      <div class="block-head-left">
        <div class="block-icon" style="background:var(--blue-bg);">◎</div>
        <span class="block-title">Referências de Perfis</span>
      </div>
      <span class="block-source src-apify">Apify</span>
    </div>
    <div class="block-body">
      <p class="ref-intro">Perfis curados como referência de posicionamento, linguagem e formato.</p>
      <% if (references && references.length > 0) { %>
      <div class="ref-list">
        <% const refColors = [{bg:'var(--blue-bg)',c:'var(--blue)'},{bg:'var(--amber-bg)',c:'var(--amber)'},{bg:'var(--green-bg)',c:'var(--green)'},{bg:'var(--purple-bg)',c:'var(--purple)'},{bg:'var(--gold-bg)',c:'var(--gold)'},{bg:'var(--red-bg)',c:'var(--red)'}]; %>
        <% references.forEach(function(ref, i) { %>
          <% const rc = refColors[i % refColors.length]; %>
          <div class="ref-card">
            <div class="ref-avatar" style="background:<%= rc.bg %>;color:<%= rc.c %>;">
              <% if (ref.profilePicUrl) { %>
                <img src="<%= ref.profilePicUrl %>" alt="@<%= ref.username %>">
              <% } else { %>
                <%= initials(ref.fullName || ref.username || '?') %>
              <% } %>
            </div>
            <div class="ref-body">
              <p class="ref-name"><%= ref.fullName || ref.username || '?' %></p>
              <p class="ref-handle">@<%= ref.username || '?' %></p>
              <% if (ref.followersCount) { %>
                <p class="ref-stats"><%= fmtNum(ref.followersCount) %> seguidores · <%= fmtNum(ref.postsCount) %> posts</p>
              <% } %>
              <% if (ref.biography) { %>
                <p style="font-size:11px;color:var(--muted);line-height:1.5;margin-top:4px;"><%= ref.biography %></p>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
      <% } else { %>
        <p style="color:var(--muted);font-size:12px;">Nenhuma referência adicionada.</p>
      <% } %>
    </div>
  </div>
</div>

<!-- ── 5. TERMOS VIRAIS ── -->
<div class="section" id="sec-termos">
  <div class="block fade-up">
    <div class="block-head">
      <div class="block-head-left">
        <div class="block-icon" style="background:var(--amber-bg);">◆</div>
        <span class="block-title">Termos Virais</span>
      </div>
      <span class="block-source src-manual">Manual</span>
    </div>
    <div class="block-body">
      <% if (viralTerm) { %>
        <div class="termo-list">
          <% viralTerm.split('\n').filter(function(t) { return t.trim(); }).forEach(function(term) { %>
            <div class="termo-card">
              <div class="termo-header">
                <span class="termo-word"><%= term.trim() %></span>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p style="color:var(--muted);font-size:12px;">Nenhum termo viral informado.</p>
      <% } %>
    </div>
  </div>
</div>

<!-- ── 6. PLANO DE AÇÃO ── -->
<div class="section" id="sec-plano">
  <div class="block fade-up">
    <div class="block-head">
      <div class="block-head-left">
        <div class="block-icon" style="background:var(--green-bg);">▶</div>
        <span class="block-title">Plano de Ação</span>
      </div>
      <span class="block-source src-ia">IA + Call</span>
    </div>
    <div class="block-body">
      <% if (actionPlan) { %>
        <div class="narr-content"><%= actionPlan %></div>
      <% } else { %>
        <p style="color:var(--muted);font-size:12px;">Plano de ação não gerado.</p>
      <% } %>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="footer">
    <p class="footer-label">Mapa do Mentorado</p>
    <p class="footer-text">@<%= client.username %></p>
    <p class="footer-sub"><%= profileName %><% if (extractedProfile && extractedProfile.especialidade) { %> · <%= extractedProfile.especialidade %><% } %></p>
    <p class="footer-date">Gerado em <%= generatedAt %></p>
  </div>
</div>

<script>
const tabs = document.querySelectorAll('.tab');
const sections = {
  perfil:'sec-perfil',
  narrativa:'sec-narrativa',
  formato:'sec-formato',
  referencias:'sec-referencias',
  termos:'sec-termos',
  plano:'sec-plano'
};

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    const key = tab.dataset.tab;
    tabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    Object.values(sections).forEach(id => {
      const el = document.getElementById(id);
      el.classList.remove('active');
      el.classList.remove('fade-up');
    });
    const target = document.getElementById(sections[key]);
    target.classList.add('active');
    void target.offsetWidth;
    target.classList.add('fade-up');
    tab.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
  });
});
</script>
</body>
</html>
